# === Model Configuration ===
# Local model via Ollama (must be pulled first: ollama pull llama3.2)
DEFAULT_LOCAL_MODEL=ollama/llama3.2
# Remote model (requires GEMINI_API_KEY)
DEFAULT_REMOTE_MODEL=gemini/gemini-2.5-flash-lite

# === API Keys / Local Access Control ===
# GEMINI_API_KEY=your-key-here
# OPENAI_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here
# DEEPSEEK_API_KEY=your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# API_ACCESS_TOKEN=shared-local-token

# === Ollama Configuration ===
OLLAMA_API_BASE=http://localhost:11434

# === Qdrant Configuration ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=personal_memories

# === Local Memory (Qdrant + Ollama only) ===
# LOCAL_MEMORY_COLLECTION=local_memories
# LOCAL_MEMORY_VECTOR_DIM=768
# LOCAL_MEMORY_MIN_CONFIDENCE=0.50
# LOCAL_MEMORY_SEMANTIC_DEDUPE_THRESHOLD=0.92
# LOCAL_MEMORY_DEDUPE_PROBE_LIMIT=6
# LOCAL_MEMORY_MAX_EXTRACT_PER_ADD=6
# LOCAL_MEMORY_MAX_CHARS=260
# LOCAL_MEMORY_EMBEDDING_CACHE_SIZE=1024
# LOCAL_MEMORY_QUERY_CACHE_SIZE=256
# LOCAL_MEMORY_QUERY_CACHE_TTL_SECONDS=20
# LOCAL_MEMORY_SEARCH_EF=96
# LOCAL_MEMORY_CANDIDATE_MULTIPLIER=5
# LOCAL_MEMORY_VECTOR_WEIGHT=0.62
# LOCAL_MEMORY_LEXICAL_WEIGHT=0.18
# LOCAL_MEMORY_RECENCY_WEIGHT=0.10
# LOCAL_MEMORY_CONFIDENCE_WEIGHT=0.10
# LOCAL_MEMORY_RECENCY_HALF_LIFE_DAYS=45
# LOCAL_MEMORY_MMR_ENABLED=true
# LOCAL_MEMORY_MMR_LAMBDA=0.72
# LOCAL_MEMORY_SCROLL_PAGE_SIZE=128

# === Embedding Configuration ===
EMBEDDING_MODEL=nomic-embed-text

# === Prompt / Context Budgets ===
RAG_CONTEXT_CHAR_BUDGET=3200
RAG_DOC_SNIPPET_CHARS=500
RAG_MEMORY_LIMIT=4
CHAT_HISTORY_MAX_MESSAGES=10
CHAT_HISTORY_CHAR_BUDGET=6000
AGENT_CONTEXT_CHAR_BUDGET=4000
WORKFLOW_CONTEXT_CHAR_BUDGET=2500

# === Agent Tooling ===
# ENABLE_AGENT_TOOL_CALLS=true
# ALLOW_EXEC_TOOLS=false
# AGENT_ALLOW_MUTATING_TOOLS=false
# AGENT_NATIVE_TOOL_CALLING_ENABLED=false
# AGENT_LEGACY_TOOL_PLANNER_FALLBACK=true
# AGENT_TOOL_LOOP_MODEL=deepseek-chat
# AGENT_TOOL_LOOP_MAX_ITERATIONS=4
# AGENT_TOOL_LOOP_MAX_CALLS=8
# AGENT_TOOL_CALL_TIMEOUT_SECONDS=20
# AGENT_PLANNER_INPUT_TOKEN_BUDGET=1200
# AGENT_TOOL_INPUT_TOKEN_BUDGET=1400
# AGENT_RESEARCHER_INPUT_TOKEN_BUDGET=1800
# AGENT_SYNTHESIZER_INPUT_TOKEN_BUDGET=2200

# === File System Tooling ===
# FS_ALLOWED_ROOTS=C:\\Users\\you\\Documents,C:\\Agents\\PersonalAssist

# === Server Configuration ===
API_HOST=127.0.0.1
API_PORT=8000

# === Desktop API Overrides (optional) ===
# VITE_API_BASE_URL=http://127.0.0.1:8000
# VITE_API_PORT=8000
# VITE_API_ACCESS_TOKEN=shared-local-token

# === Desktop Backend Autostart (Tauri) ===
# PERSONALASSIST_API_AUTOSTART=true
# PERSONALASSIST_PYTHON=python
# PERSONALASSIST_API_LOG=~/.personalassist/backend_logs.txt

# === Podcast Agent Configuration ===
# PODCAST_OUTPUT_DIR=~/Downloads
# TTS_PROVIDER=edge-tts
# ELEVENLABS_API_KEY=your-key-here
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# PODCAST_QDRANT_COLLECTION=podcast_research
# PODCAST_MAX_DURATION=120
