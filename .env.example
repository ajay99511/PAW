# === Model Configuration ===
# Local model via Ollama (must be pulled first: ollama pull llama3.2)
DEFAULT_LOCAL_MODEL=ollama/llama3.2
# Remote model (requires GEMINI_API_KEY)
DEFAULT_REMOTE_MODEL=gemini/gemini-2.0-flash

# === API Keys (optional, for remote models) ===
# GEMINI_API_KEY=your-key-here
# OPENAI_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here

# === Ollama Configuration ===
OLLAMA_API_BASE=http://localhost:11434

# === Qdrant Configuration ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=personal_memories

# === Embedding Configuration ===
EMBEDDING_MODEL=nomic-embed-text

# === Server Configuration ===
API_HOST=127.0.0.1
API_PORT=8000

# === Podcast Agent Configuration ===
# PODCAST_OUTPUT_DIR=~/Downloads
# TTS_PROVIDER=edge-tts
# ELEVENLABS_API_KEY=your-key-here
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# PODCAST_QDRANT_COLLECTION=podcast_research
# PODCAST_MAX_DURATION=120
